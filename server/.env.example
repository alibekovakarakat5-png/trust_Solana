# AI Provider: 'alemllm' | 'openai' | 'anthropic' | 'mock'
AI_PROVIDER=alemllm

# AlemLLM (Alem Plus — Kazakhstan AI, OpenAI-compatible)
ALEM_API_KEY=your_alem_api_key
ALEM_API_URL=https://llm.alem.ai/v1/chat/completions

# OpenAI (alternative)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative)
ANTHROPIC_API_KEY=sk-ant-...

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
ORACLE_PRIVATE_KEY=[1,2,3...]

PORT=3001
