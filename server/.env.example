# AI Provider: alemllm | openai | anthropic | mock
AI_PROVIDER=alemllm
ALEM_API_KEY=your_alem_api_key
ALEM_API_URL=https://llm.alem.ai/v1/chat/completions

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com

# Oracle keypair (JSON array of secret key bytes)
# Generate: solana-keygen new --outfile oracle.json
# Then paste the array here
ORACLE_PRIVATE_KEY=[1,2,3,...your_64_byte_secret_key]

PORT=3001
